<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TypeScriptCompileBlocked>true</TypeScriptCompileBlocked>
    <TypeScriptToolsVersion>Latest</TypeScriptToolsVersion>
    <IsPackable>false</IsPackable>
    <SpaRoot>ClientApp\</SpaRoot>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(SpaRoot)node_modules\**</DefaultItemExcludes>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <TargetFramework>net10.0</TargetFramework>
    <!-- Files which predate this have '#nullable disable' and are being migrated file-by-file -->
    <Nullable>enable</Nullable>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <!-- Required for IDE0005 (unused usings) to be reported at build time (dotnet/roslyn#41640) -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Don't require XML doc comments on public members (1591) or on every parameter (1573) -->
    <NoWarn>$(NoWarn);CS1591;CS1573</NoWarn>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Keep NuGet audit findings as warnings (#227). They introduce temporal coupling.
    The 'Dependency Audit' workflow and Dependabot are better for this use case. -->
    <WarningsNotAsErrors>NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CsvHelper" Version="33.1.0" />
    <PackageReference Include="HtmlAgilityPack" Version="1.12.4" />
    <PackageReference Include="Lucene.Net" Version="4.8.0-beta00018" />
    <PackageReference Include="Lucene.Net.Analysis.Common" Version="4.8.0-beta00018" />
    <PackageReference Include="Microsoft.AspNetCore.SpaServices.Extensions" Version="10.0.10" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="sly" Version="3.8.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Don't publish the SPA source files, but do show them in the project files list -->
    <Content Remove="$(SpaRoot)**" />
    <None Remove="$(SpaRoot)**" />
    <None Include="$(SpaRoot)**" Exclude="$(SpaRoot)node_modules\**" />
    <None Update="newdocs">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="tools\download_cregeen.sh">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="tools\download_kelly_m2e.sh">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="tools\init.sh">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\.dockerignore">
      <Link>.dockerignore</Link>
    </Content>
    <Content Include="Resources\*.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- The lemma table, pinned by the external/manx-lemma-data submodule
    (inside the project so it reaches the Docker build context); published as
    Resources/cregeen.tsv. The pin is what dev/tests run against and what the
    image boots with as a fallback: production overwrites it with the repo's
    HEAD on container start (tools/init.sh) -->
    <Content Include="external\manx-lemma-data\cregeen.tsv">
        <Link>Resources\cregeen.tsv</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- The Culture Vannin spoken dictionary (generated from cregeen-nvh
    spoken/spoken.nvh): popup entries with pronunciation audio streamed from
    learnmanx.com -->
    <!-- Update, not Include: the Web SDK already includes json files as Content -->
    <Content Update="external\manx-lemma-data\spoken.json"
             Condition="Exists('external\manx-lemma-data\spoken.json')">
        <Link>Resources\spoken.json</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- The proper-nouns supplement (generated from cregeen-nvh names.nvh):
    loaded beside cregeen.tsv when present -->
    <Content Include="external\manx-lemma-data\names.tsv"
             Condition="Exists('external\manx-lemma-data\names.tsv')">
        <Link>Resources\names.tsv</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- The Phillips 1610 spelling supplement (generated from cregeen-nvh
    phillips.nvh): loaded beside cregeen.tsv when present -->
    <Content Include="external\manx-lemma-data\phillips.tsv"
             Condition="Exists('external\manx-lemma-data\phillips.tsv')">
        <Link>Resources\phillips.tsv</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- The disambiguation layers ride beside the table (LemmaResolver);
    optional until the data repo adopts the generated artifacts -->
    <Content Include="external\manx-lemma-data\lemma.overrides.tsv"
             Condition="Exists('external\manx-lemma-data\lemma.overrides.tsv')">
        <Link>Resources\lemma.overrides.tsv</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="external\manx-lemma-data\lemma.sidecar.tsv"
             Condition="Exists('external\manx-lemma-data\lemma.sidecar.tsv')">
        <Link>Resources\lemma.sidecar.tsv</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
</ItemGroup>

  <!-- Files copied in from a public GitHub -->
  <ItemGroup>
    <Content Include="OpenData\**">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Due to copyright, we don't want to include some of the files on a public GitHub, but we do want to include them in the corpus -->
  <ItemGroup>
    <Content Include="ClosedData\**">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Remove="Resources\ParnellTheHermit.csv" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Views\Shared\" />
  </ItemGroup>


  <Target Name="DebugEnsureNodeEnv" BeforeTargets="Build" Condition=" '$(Configuration)' == 'Debug' And !Exists('$(SpaRoot)node_modules') ">
    <!-- Ensure Node.js is installed -->
    <Exec Command="node --version" ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="ErrorCode" />
    </Exec>
    <Error Condition="'$(ErrorCode)' != '0'" Text="Node.js is required to build and run this project. To continue, please install Node.js from https://nodejs.org/, and then restart your command prompt or IDE." />
    <Message Importance="high" Text="Restoring dependencies using 'npm'. This may take several minutes..." />
    <Exec WorkingDirectory="$(SpaRoot)" Command="npm install" />
  </Target>

  <Target Name="PublishRunWebpack" AfterTargets="ComputeFilesToPublish">
    <!-- As part of publishing, ensure the JS resources are freshly built in production mode -->
    <Exec WorkingDirectory="$(SpaRoot)" Command="npm install" />
    <Exec WorkingDirectory="$(SpaRoot)" Command="npm run build" />

    <!-- Include the newly-built files in the publish output -->
    <ItemGroup>
      <DistFiles Include="$(SpaRoot)build\**" />
      <ResolvedFileToPublish Include="@(DistFiles->'%(FullPath)')" Exclude="@(ResolvedFileToPublish)">
        <RelativePath>%(DistFiles.Identity)</RelativePath>
        <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      </ResolvedFileToPublish>
    </ItemGroup>
  </Target>

</Project>
