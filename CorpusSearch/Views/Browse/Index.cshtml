@using CorpusSearch.Model

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Manx Corpus - Full Document Listing</title>
    <link rel="shortcut icon" href="/favicon.ico">
    @* version query = server start time, so a rebuild+restart always busts cached CSS *@
    <link href="/site-design.css?v=@(System.Diagnostics.Process.GetCurrentProcess().StartTime.Ticks)" rel="stylesheet">
</head>
<body>

@{
    ViewData["ActiveNav"] = "browse";
    var documents = ViewData["Documents"] as List<IDocument> ?? [];
}

@await Html.PartialAsync("_SiteHeader")

<div class="page-main">
    <h1 class="page-title">Full Document Listing</h1>

    <div class="browse-controls">
        <div class="browse-count">@documents.Count.ToString("N0") documents</div>
        <div class="browse-order">
            <span class="browse-order-label">Order by</span>
            <div class="seg-control">
                <button type="button" id="order-date" class="active">Date</button>
                <button type="button" id="order-alpha">A–Z</button>
            </div>
        </div>
    </div>

    <div class="browse-list" id="browse-list">
        @foreach (var document in documents.OrderBy(x => x.CreatedCircaStart)
                      .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                      .ThenBy(x => x.Ident, StringComparer.Ordinal))
        {
            var year = document.GetFullYear();
            <div class="browse-row" data-title="@document.Name">
                <span class="browse-year">
                    @if (!string.IsNullOrEmpty(year))
                    {
                        <span class="year-badge">@year</span>
                    }
                </span>
                <span class="browse-text">
                    <a href="/docs/@Uri.EscapeDataString(document.Ident)">@document.Name</a>
                    @if (!string.IsNullOrEmpty(document.Source))
                    {
                        <span class="browse-source">@document.Source</span>
                    }
                </span>
            </div>
        }
    </div>

    @await Html.PartialAsync("_SiteFooter")
</div>

<script>
    (function () {
        const list = document.getElementById("browse-list");
        const dateButton = document.getElementById("order-date");
        const alphaButton = document.getElementById("order-alpha");
        const byDate = Array.from(list.children);
        // sort on the first letter: ignore leading whitespace, quotes and emoji (e.g. "🎥 Captan…" under C)
        const sortKey = row => (row.dataset.title || "")
            .replace(/^[^\p{L}\p{N}]+/u, "")
            .toLowerCase();
        const byTitle = byDate.slice().sort((a, b) => sortKey(a).localeCompare(sortKey(b)));

        function show(rows, active, inactive) {
            list.replaceChildren(...rows);
            active.classList.add("active");
            inactive.classList.remove("active");
        }

        dateButton.addEventListener("click", () => show(byDate, dateButton, alphaButton));
        alphaButton.addEventListener("click", () => show(byTitle, alphaButton, dateButton));
    })();
</script>

</body>
</html>
